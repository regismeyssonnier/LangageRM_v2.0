class Sep {
	char separator;
	char* buffer;
	int w = 0;
	int h = 0;

	constructor Sep(char sep, int w, int h) {
		this.separator = sep;
		this.buffer = new string[w * h];
		this.w = w;
		this.h = h;

		for (int i = 0; i < this.h; i = i + 1) {
			for (int j = 0; j < this.w; j = j + 1) {
				this.buffer[i * this.w + j] = 0;
			}
		}
	}

	func char getseparator() {
		return this.separator;
	}

	func void setseparator(char s) {
		this.separator = s;
	}

	func void Set(int x, int y, char val) {
		this.buffer[y * this.w + x] = val;
	}

	func char Get(int x, int y) {
		return this.buffer[y * this.w + x];
	}

	func void _free() {
		free(this.buffer);
	}

}

class Regex {
    string pattern;

    constructor Regex(string p) {
        this.pattern = p;
    }

    func int pat_len() {
        int ln = 0;
        while (this.pattern[ln]) {
            ln = ln + 1;
        }
        return ln;
    }

    func int str_len(string s) {
        int ln = 0;
        while (s[ln]) {
            ln = ln + 1;
        }
        return ln;
    }

    func bool Match(string text) {
        int plen = this.pat_len();
        int tlen = this.str_len(text);

     

        for (int i = 0; i <= (tlen - plen); i = i + 1) {
            bool ok = true;
            for (int j = 0; j < plen; j = j + 1) {
        
                if (text[i + j] != this.pattern[j]) {
                    ok = false;
                }
                else {}
            }
            if (ok == true) {

                return true;
            }
            else {}
        }
        return false;
    }

    func string Replace(string text, string repl) {
        int plen = this.pat_len();
        int tlen = this.str_len(text);
        int rlen = this.str_len(repl);

        int pos = -1;
        for (int i = 0; i <= tlen - plen; i = i + 1) {
            bool ok = true;
            for (int j = 0; j < plen; j = j + 1) {
      
                if (text[i + j] != this.pattern[j]) {
                    ok = false;
                }
                else {}
            }
            if (ok) {
                pos = i;
                i = tlen;
            }
            else {}
        }

        if (pos == -1) {
            return text;
        }
        else {}

        int newsize = tlen - plen + rlen;
        char* result = new char[newsize + 1];
        int k = 0;

        for (int i = 0; i < pos; i = i + 1) {
            result[k] = text[i];
            k = k + 1;
        }

        for (int i = 0; i < rlen; i = i + 1) {
            result[k] = repl[i];
            k = k + 1;
        }

        for (int i = pos + plen; i < tlen; i = i + 1) {
            result[k] = text[i];
            k = k + 1;
        }

        result[k] = '\0';

        return result;
    }

    func string ReplaceAll(string text, string repl) {
        int plen = this.pat_len();
        int tlen = this.str_len(text);
        int rlen = this.str_len(repl);

        // Compter les occurrences
        int count = 0;
        for (int i = 0; i <= tlen - plen; i = i + 1) {
            bool ok = true;
            for (int j = 0; j < plen; j = j + 1) {
                if (text[i + j] != this.pattern[j]) {
                    ok = false;
                }
                else {}
            }
            if (ok) {
                count = count + 1;
                i = i + plen - 1;
            }
            else {}
        }

        if (count == 0) {
            return text;
        }
        else {}

        int newsize = tlen + count * (rlen - plen);
        char* result = new char[newsize + 1];
        int k = 0;
        int i = 0;

        while (i < tlen) {
            bool ok = i <= tlen - plen;
            if (ok) {
                for (int j = 0; j < plen; j = j + 1) {
                    if (text[i + j] != this.pattern[j]) {
                        ok = false;
                    }
                    else {}
                }
            }
            else {}

            if (ok) {
                for (int j = 0; j < rlen; j = j + 1) {
                    result[k] = repl[j];
                    k = k + 1;
                }
                i = i + plen;
            }
            else {
                result[k] = text[i];
                k = k + 1;
                i = i + 1;
            }
        }

        result[k] = '\0';
        return result;
    }

    func int Count(string text) {
        int plen = this.pat_len();
        int tlen = this.str_len(text);
        int count = 0;

        for (int i = 0; i <= tlen - plen; i = i + 1) {
            bool ok = true;
            for (int j = 0; j < plen; j = j + 1) {
                if (text[i + j] != this.pattern[j]) {
                    ok = false;
                }
                else {}
            }
            if (ok) {
                count = count + 1;
                i = i + plen - 1;
            }
            else {}
        }
        return count;
    }
}

class SuperChaine {
	char* buffer;
	int size_buffer;
	constructor SuperChaine(string s){


		int sz = 0;
		while (s[sz]) {
			sz = sz + 1;
		}

		this.size_buffer = sz;
		this.buffer = new char[this.size_buffer];

		int ln = 0;
		while (s[ln]) {
			this.buffer[ln] = s[ln];
			ln = ln + 1;
		}

		print("size=");
		println(this.size_buffer);
		print("buffer=");
		for (int i = 0; i < this.size_buffer; i = i+1) {
			print(this.buffer[i]);
		}

	}

	func void Split(Sep *osep) {
		println("split");

		int count = 0;
		int index = 0;
		for (int j = 0; j < this.size_buffer; j = j + 1) {
			if (this.buffer[j] == osep->getseparator()) {
				count += 1;
				index = 0;
			}
			else {
				osep->Set(index, count, this.buffer[j]);
				index += 1;
			}
		}
		
		if (index > 0) {
			count += 1;
		}
		else{}
		
		print("nb_sep=");
		println(count);

		for (int i = 0; i < count; i = i + 1) {
			int j = 0;
			print(i);
			print("=");
			while (osep->Get(j, i) != '\0') {
				print(osep->Get(j, i));
				j += 1;
			}
			println("");
		}


	}


}

