class Personne {
    string nom;
    int age;
    
    constructor Personne(string nom, int age) {
        this.nom = nom;
        this.age = age;
    }
    
    func void Afficher() {
        print("Nom: ");
        println(this.nom);
        print("Age: ");
        println(this.age);
    }
    
    func string GetNom() {
        return this.nom;
    }
}

class ChaineManage {
    char buffer[256];
    int size = 0;

    constructor ChaineManage(string s) {
        int ln = 0;
        while (s[ln]) {
            char c = s[ln];
            this.buffer[ln] = c;
            println(s[ln]);
            ln = ln + 1;
        }
        this.size = ln;
        this.buffer[ln] = '\0';

    }


    func int Len() {
        return this.size;
    }

    func string Concat(ChaineManage s) {
      
        int i = 0;
        while (i < s.size) {
            this.buffer[this.size + i] = s.buffer[i];
            i = i + 1;
        }
        
        this.size = this.size + s.size;
        this.buffer[this.size] = '\0';
        
          return this.buffer;


    }


}

class TabN {
    char buffer[100];
    int size = 0;
    int w = 0;
    int h = 0;

    constructor TabN(int w, int h) {
        this.w = w;
        this.h = h;
        
    }

    func void Set(int x, int y, char val) {
        this.buffer[y * this.w + x] = val;
    }

    func char Get(int x, int y) {
        return this.buffer[y * this.w + x];
    }

    func void Display() {
        for (int i = 0; i < this.h; i = i + 1) {
            for (int j = 0; j < this.w; j = j + 1) {
                print(this.buffer[i * this.w + j]);
                print(" ");
            }println("");
        }println("");
    }
        
}

class TabN2 {
    char buffer[1000];  // buffer plus grand pour 3D
    int size = 0;
    int w = 0;
    int h = 0;
    int d = 0;  // profondeur pour la 3ème dimension

    constructor TabN2(int w, int h, int d) {
        this.w = w;
        this.h = h;
        this.d = d;
    }

    func void Set(int x, int y, int z, char val) {
        // Index 3D : z * (w*h) + y * w + x
        this.buffer[z * this.w * this.h + y * this.w + x] = val;
    }

    func char Get(int x, int y, int z) {
        return this.buffer[z * this.w * this.h + y * this.w + x];
    }

    func void Display() {
        for (int k = 0; k < this.d; k = k + 1) {
            println("Couche ", k, ":");
            for (int i = 0; i < this.h; i = i + 1) {
                for (int j = 0; j < this.w; j = j + 1) {
                    print(this.buffer[k * this.w * this.h + i * this.w + j]);
                    print(" ");
                }
                println("");
            }
            println("");
        }
    }
}

class math {
    double number = 0.0;

    constructor math(double n) {
        this.number = n;
    }




}

// 5. Char dans une classe
class Test {
