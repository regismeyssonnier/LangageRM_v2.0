    print("w=");
    println(w);


    // CORRECTION ICI : Utiliser une variable temporaire
    for(int k = 0; k < 2; k = k + 1) {
        Personne p = Personne(noms[k], k * 10);
        personnes[k] = p;
        Personne x = personnes[k];
        x.Afficher();
        x.age = x.age + 5;
