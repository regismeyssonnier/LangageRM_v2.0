    // Tableau de chaînes
    string noms[3] = {"Alice", "Bob", "Charlie"};
    noms[0] = "trouduc";
    string nom = "Louis";
    int index = 0;
    println(nom[index]);
    while (nom[index]) {
        println(nom[index]);
        index = index + 1;
    }
    print("index=");
