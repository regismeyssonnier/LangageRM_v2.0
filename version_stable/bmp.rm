class BMPLoader {
    // BMP file header structure
    int fileHeaderSize;
    int dibHeaderSize;
    int width;
    int height;
    int bitsPerPixel;
    int compression;
    int imageSize;
    int colorsUsed;
    int dataOffset;

    // Pixel data storage
    char* pixelData;// = new char[8000];
    char rgb[3];

    string fileHandle;

    // Constructor
    constructor BMPLoader() {
        this.fileHeaderSize = 14;
        this.dibHeaderSize = 40;
        this.width = 0;
        this.height = 0;
        this.bitsPerPixel = 0;
        this.compression = 0;
        this.imageSize = 0;
        this.colorsUsed = 0;
        this.dataOffset = 0;
        this.pixelData = new char[8000];
        
    }

    func void _freeObject() {
        free(this.pixelData);
    }

    // Main method to load a BMP file
    func bool loadBMP(string filename) {
        // Open file in binary mode
        this.fileHandle = file_open(filename, READ_BIN);
        
        if (this.fileHandle == null) {
            println("Error: Cannot open file ");
            println(filename);
            return false;
        }
        else {

        }

        // 1. Read file header (14 bytes)
        char signature1 = file_read_bin(this.fileHandle, char);
        char signature2 = file_read_bin(this.fileHandle, char);

        println("signature=");
        println(signature1);
        println(signature2);

        // Check BM signature (0x4D42 in little-endian)
        if (signature1 != 66 && signature2 != 77) {
            println("Error: Invalid BMP format (bad signature)");
            file_close(this.fileHandle);
            return false;
        }
        else {

        }

        // Read total file size (ignored for now)
        int fileSize = file_read_bin(this.fileHandle, int);

        // Read 2 reserved bytes (ignored)
        int reserved1 = file_read_bin(this.fileHandle, int);
        //char reserved12 = file_read_bin(fileHandle, char);
        //char reserved2 = file_read_bin(fileHandle, char);
        //char reserved22 = file_read_bin(fileHandle, char);

        // Read data offset (where pixel data starts)
        this.dataOffset = file_read_bin(this.fileHandle, int);

        // 2. Read DIB header (40 bytes for standard version)
        int dibSize = file_read_bin(this.fileHandle, int);

        /*if (dibSize != 40) {
            print("Error: Unsupported BMP version (DIB size = ");
            print(dibSize); 
            println(")");
            file_close(fileHandle);
            return false;
        }
        else {

        }*/

        this.width = file_read_bin(this.fileHandle, int);
        this.height = file_read_bin(this.fileHandle, int);
        char plan1 = file_read_bin(this.fileHandle, char);
        char plan2 = file_read_bin(this.fileHandle, char);
        this.bitsPerPixel = 24;// 
        char bpx = file_read_bin(this.fileHandle, char);
        char bpx2 = file_read_bin(this.fileHandle, char);
        this.compression = file_read_bin(this.fileHandle, int);
        this.imageSize = file_read_bin(this.fileHandle, int);

        // Skip other fields for simplicity
        int xPixelsPerMeter = file_read_bin(this.fileHandle, int);
        int yPixelsPerMeter = file_read_bin(this.fileHandle, int);
        this.colorsUsed = file_read_bin(this.fileHandle, int);
        int colorsImportant = file_read_bin(this.fileHandle, int);

        // 3. Display image information
        println("=== BMP Information ===");
        print("Width       : ");
        println(this.width);
        print("Height      : ");
        println(this.height);
        print("Bits/pixel  : ");
        println(this.bitsPerPixel);
        print("Compression : "); 
        println(this.compression);
        print("Data size   : ");
        println(this.imageSize);
        print("Data offset : ");
        println(this.dataOffset);
        println("======================");

        // Check if format is supported
        if (this.bitsPerPixel != 24 && this.bitsPerPixel != 32 && this.bitsPerPixel != 8) {
            println("Error: Unsupported pixel format (");
            println(this.bitsPerPixel);
            println(" bits/pixel)");
            file_close(this.fileHandle);
            return false;
        }
        else {

        }


        if (this.compression != 0) {
            println("Error: Unsupported compression (compression = ");
            println(this.compression);
            println(")");
            file_close(this.fileHandle);
            return false;
        }
        else {

        }

        // 4. Position at start of pixel data
        // For simplicity, we position manually
        // In a real program we would use file_seek to position at dataOffset

        // 5. Load pixel data
        bool result = this.loadPixelData(this.fileHandle);

        // Close file
        file_close(this.fileHandle);

        return result;
    }

    // Method to load pixel data
    func bool loadPixelData(string fileHandle) {


        int bytesPerPixel = this.bitsPerPixel / 8;

        // Calculate row size with alignment (multiple of 4)
        int rowSize = this.width * bytesPerPixel;
        int paddingSize = 0;

        // Padding must make rowSize a multiple of 4
        while ((rowSize + paddingSize) % 4 != 0) {
            paddingSize = paddingSize + 1;
        }

        int totalRowSize = rowSize + paddingSize;
        int totalPixels = this.width * this.height;

        // Create array to store all pixels (in RGB)
        //this.pixelData = new int[totalPixels * 3]; // 3 components: R, G, B

        // For each row (bottom to top)
        int rowIndex = 0;
        for (int y = this.height - 1; y >= 0; y = y - 1) {
            // Read one entire row (including padding)
            char rowData[150];

            // Read byte by byte (simplified)
            for (int i = 0; i < totalRowSize; i = i + 1) {
                rowData[i] = file_read_bin(fileHandle, char);
            }

            // Extract pixels from row (ignore padding)
            for (int x = 0; x < this.width; x = x + 1) {
                int pixelIndex = x * bytesPerPixel;
                int outputIndex = rowIndex * this.width * 3 + x * 3;

                if (bytesPerPixel == 3) {
                    // BGR format (24 bits)
                    char blue = rowData[pixelIndex];
                    char green = rowData[pixelIndex + 1];
                    char red = rowData[pixelIndex + 2];

                    this.pixelData[outputIndex] = red;
                    this.pixelData[outputIndex + 1] = green;
                    this.pixelData[outputIndex + 2] = blue;
                }
                else if (bytesPerPixel == 4) {
                    // BGRA format (32 bits)
                    char blue = rowData[pixelIndex];
                    char green = rowData[pixelIndex + 1];
                    char red = rowData[pixelIndex + 2];
                    // int alpha = rowData[pixelIndex + 3]; // Ignored for simplicity

                    this.pixelData[outputIndex] = red;
                    this.pixelData[outputIndex + 1] = green;
                    this.pixelData[outputIndex + 2] = blue;
                }
                else if (bytesPerPixel == 1) {
                    // Indexed format (8 bits) - requires palette
                    /*int index = rowData[pixelIndex];
                    // For simplicity, convert index to grayscale
                    int gray = index * 255 / 255; // Simple normalization
                    this.pixelData[outputIndex] = gray;
                    this.pixelData[outputIndex + 1] = gray;
                    this.pixelData[outputIndex + 2] = gray;*/
                }
            }

            rowIndex = rowIndex + 1;
        }

        // Display some information about loaded data
        int pixelCount = this.width * this.height;
        print("Data loaded: ");
        print(pixelCount);
        println(" pixels");
        print("First pixel (R,G,B): ");
        print(this.pixelData[0]);
        print(", ");
        print(this.pixelData[1]);
        print(", ");
        println(this.pixelData[2]);
        print("Last pixel (R,G,B) : ");
        print(this.pixelData[(pixelCount - 1) * 3]);
        print(", ");
        print(this.pixelData[(pixelCount - 1) * 3 + 1]);
        print(", ");
        println(this.pixelData[(pixelCount - 1) * 3 + 2]);

        return true;
    }


